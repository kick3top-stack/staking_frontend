# Copy this to .env and fill in your deployed contract addresses

# JSON-RPC endpoint for read-only calls (no wallet required)
# Hardhat local node default:
VITE_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/
# For a public testnet e.g. Sepolia:
# VITE_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Address of the StakingERC1967Proxy (the proxy contract)
VITE_STAKING_PROXY_ADDRESS=0x08c4390bf06080E8775Ed2c5fb5C4E36a465435C

# Address of the MockERC20 (or your real staking token)
VITE_TOKEN_ADDRESS=0x7D72143Ee6A6bb2E710e1Aa3CE19fcFBA3423220

# Token symbol shown in the UI (e.g. MOCK, USDC, etc.)
VITE_TOKEN_SYMBOL=MOCK

# Token decimals (default 18)
VITE_TOKEN_DECIMALS=18
